# Build outputs
bin/
obj/
*.user
*.suo
.vs/

# NuGet pack output (CI publishes from a fresh pack)
nupkgs/
nupkgs-test/
*.nupkg
*.snupkg

# Secrets — NEVER commit these
appsettings.Production.json
appsettings.secrets.json
*.pfx
*.key
nugetkey.txt
nuget.api.key
*nugetkey*

# Upload storage — should never be in source control
uploads/
scan-temp/

# Local pack-inspection scratch (unpacked nupkg contents, compiled DLLs) —
# binaries must never land in source control
_extract/
_verify/
_pack_inspect/

# IDE
.vscode/
.idea/
*.swp
