    <!-- ── XML doc generation ──────────────────────────────────────────── -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Suppress "missing XML doc" warnings for members that aren't yet documented -->
    <NoWarn>1591</NoWarn>

    <!-- ── Treat warnings as errors in CI builds ───────────────────────── -->
    <TreatWarningsAsErrors Condition="'$(GITHUB_ACTIONS)' == 'true'">false</TreatWarningsAsErrors>
  </PropertyGroup>

  <!-- ── Runtime dependencies ─────────────────────────────────────────── -->
  <!--
    Microsoft.AspNetCore.App ships as a shared framework on the target machine —
    referencing it here means it will NOT be bundled inside the package.
    Resolves to the matching ASP.NET Core 8.0 / 9.0 / 10.0 shared framework for
    each TFM. Consumers need ASP.NET Core present at one of those versions.
  -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- Image identification + recompression (polyglot-tail mitigation) -->
    <PackageReference Include="SixLabors.ImageSharp" Version="4.0.0" />

    <!--
      Argon2id key derivation for the master Key Encryption Key (KEK).
      Memory-hard KDF; RFC 9106; OWASP 2024+ recommendation.
      Used in FileUploadService for the Argon2id KEK derivation path.
    -->
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" Version="1.3.1" />

    <!-- Source Link: maps debug symbols back to the GitHub source tree -->
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
  </ItemGroup>

  <!-- ── Source file layout ────────────────────────────────────────────── -->
  <!--
    All source lives directly in src/ alongside this project file.
    ReplacementCardInputModel.cs is an application-level sample — excluded
    from the library so it doesn't pollute the package API surface.
  -->
  <ItemGroup>
    <Compile Remove="ReplacementCardInputModel.cs" />
  </ItemGroup>

  <!-- ── Pack: include README, LICENSE, and security docs in the package ── -->
  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="\" />
    <None Include="../LICENSE" Pack="true" PackagePath="\" />
    <None Include="../SECURITY.md" Pack="true" PackagePath="\" />
